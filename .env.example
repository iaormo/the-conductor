# the-conductor environment variables

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED — Must be set for system operation
# ═══════════════════════════════════════════════════════════════════════════

# Apollo CRM API (Business Development Division)
# Get your API key from: https://app.apollo.io/settings/api
APOLLO_API_KEY=your_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Defaults provided if not set
# ═══════════════════════════════════════════════════════════════════════════

# Persistence & Database
# Default: persistence/audit.db (created at repo root)
DATABASE_PATH=persistence/audit.db

# Security Division Configuration

# SAST Scanner Configuration
# Java-based static analysis tool for code security
SAST_SCAN_TIMEOUT=300
SAST_MEMORY_LIMIT=4096

# Dependency Checker Configuration
# Checks for vulnerable dependencies in package managers
DEPENDENCY_CHECK_DB_PATH=persistence/dependency_check_db
DEPENDENCY_CHECK_TIMEOUT=120

# Cloud Security Scanner Configuration
# Scans AWS, Azure, GCP for misconfigurations
AWS_PROFILE=default
AZURE_SUBSCRIPTION_ID=
GCP_PROJECT_ID=

# Compliance Configuration
# Compliance automation and gap analysis
COMPLIANCE_FRAMEWORK=soc2
# Options: soc2, iso27001, hipaa, pci-dss, gdpr, ccpa, nist
COMPLIANCE_STRICTNESS=strict
# Options: strict, moderate, lenient

# Incident Response Configuration
# IR tools, forensics, threat hunting
INCIDENT_RESPONSE_ALERT_THRESHOLD=high
FORENSICS_LOG_PATH=/var/log
THREAT_HUNT_DATA_SOURCE=security_events

# ═══════════════════════════════════════════════════════════════════════════
# Business Development Division Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Lead Generation Settings
LEAD_GEN_DEFAULT_LIMIT=50
LEAD_GEN_MAX_LIMIT=500
LEAD_GEN_MIN_FIT_SCORE=60

# Enrichment Settings
ENRICHMENT_EMAIL_VERIFICATION=true
ENRICHMENT_PHONE_VERIFICATION=true
ENRICHMENT_DEDUPLICATE=true

# Outreach Configuration
OUTREACH_EMAIL_TEMPLATE_PATH=templates/outreach
OUTREACH_A_B_VARIANTS=2
OUTREACH_TOUCH_COUNT=5
OUTREACH_FOLLOW_UP_DAYS=14

# CRM Configuration
CRM_TYPE=apollo
# Options: apollo, salesforce, hubspot, pipedrive, custom
CRM_SYNC_DEDUPLICATE=true
CRM_CREATE_ACCOUNTS=true
CRM_ASSIGN_LABELS=true

# ═══════════════════════════════════════════════════════════════════════════
# Client Delivery Division Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Project Management
PROJECT_MANAGEMENT_TOOL=internal
# Options: internal, jira, asana, monday, clickup
PROJECT_MILESTONE_TRACKING=true
PROJECT_ALERT_THRESHOLD=yellow

# SOW & Contracts
SOW_TEMPLATE_PATH=templates/sow
SOW_AUTO_GENERATE=false
SOW_REQUIRE_REVIEW=true

# Invoicing
INVOICE_TEMPLATE_PATH=templates/invoicing
INVOICE_CURRENCY=USD
INVOICE_TAX_RATE=0.00
INVOICE_DUE_DAYS=30

# Client Reporting
REPORTING_FREQUENCY=weekly
REPORTING_INCLUDE_METRICS=true
REPORTING_INCLUDE_FORECASTS=true

# ═══════════════════════════════════════════════════════════════════════════
# Development Division Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Code Generation
CODE_GEN_FRAMEWORK=default
CODE_GEN_LANGUAGE_DEFAULT=python

# Code Review
CODE_REVIEW_CHECK_TESTS=true
CODE_REVIEW_CHECK_DOCS=true
CODE_REVIEW_MIN_COVERAGE=70

# CI/CD Pipeline
CICD_PLATFORM=github-actions
# Options: github-actions, gitlab-ci, jenkins, circleci, bitbucket-pipelines
CICD_AUTO_DEPLOY=false
CICD_REQUIRE_APPROVAL=true

# Documentation
DOCS_TEMPLATE_PATH=templates/docs
DOCS_AUTO_GENERATE=true
DOCS_INCLUDE_EXAMPLES=true

# ═══════════════════════════════════════════════════════════════════════════
# Data & Analytics Division Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Data Extraction
DATA_EXTRACTION_SOURCES=csv,json,sql,api
DATA_EXTRACTION_VALIDATION=true
DATA_EXTRACTION_DEDUPLICATION=true

# Business Intelligence
BI_TOOL=internal
# Options: internal, tableau, looker, power-bi, metabase
BI_REFRESH_FREQUENCY=daily
BI_CACHE_RESULTS=true

# Market Research
MARKET_RESEARCH_DATA_SOURCES=public_apis,industry_reports
MARKET_RESEARCH_CACHE_DAYS=30

# Competitive Intelligence
COMPETITIVE_INTEL_AUTO_UPDATE=true
COMPETITIVE_INTEL_TRACK_COMPETITORS=true
COMPETITIVE_INTEL_ALERT_ON_CHANGE=true

# ═══════════════════════════════════════════════════════════════════════════
# Marketing & Content Division Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Content Writing
CONTENT_TEMPLATE_PATH=templates/content
CONTENT_DEFAULT_LENGTH=medium
CONTENT_INCLUDE_SEO=true
CONTENT_TONE=professional

# Email Campaigns
EMAIL_PROVIDER=sendgrid
# Options: sendgrid, mailgun, aws-ses, mailchimp, custom
EMAIL_TEMPLATE_PATH=templates/email
EMAIL_UNSUBSCRIBE_LINK=true
EMAIL_TRACKING=true

# Social Media
SOCIAL_PLATFORM=native
# Options: native, hootsuite, buffer, sprout-social, custom
SOCIAL_AUTO_POST=false
SOCIAL_SCHEDULE_TIMEZONE=UTC

# SEO
SEO_CHECK_TOOLS=builtwith,semrush_api
SEO_TARGET_KEYWORD_DENSITY=2.5
SEO_MIN_WORD_COUNT=500

# ═══════════════════════════════════════════════════════════════════════════
# Automation & Integration Division Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Workflow Automation
WORKFLOW_PLATFORM=zapier
# Options: zapier, make, n8n, power-automate, internal
WORKFLOW_AUTO_ENABLE=false
WORKFLOW_ERROR_HANDLING=alert_and_retry

# API Integration
API_TIMEOUT=30
API_RETRY_COUNT=3
API_RATE_LIMIT_HANDLING=exponential_backoff

# Scheduling
SCHEDULER_TIMEZONE=UTC
CRON_LOG_PATH=persistence/cron_logs
SCHEDULER_ENABLE_NOTIFICATIONS=true

# Alerting
ALERTING_ENGINE=internal
ALERT_CHANNELS=email,slack
ALERT_CRITICAL_ESCALATION=true
SLACK_WEBHOOK_URL=
ALERT_DEDUPLICATION=true

# ═══════════════════════════════════════════════════════════════════════════
# System & Infrastructure Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Application Environment
NODE_ENV=production
# Options: development, staging, production

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error, critical
LOG_FORMAT=json
LOG_PATH=logs

# Performance
AGENT_CONCURRENCY=4
MEMORY_LIMIT_MB=2048
TIMEOUT_DEFAULT_MS=30000

# External Monitoring & Analytics
SENTRY_DSN=
# Sentry error tracking (optional)
DATADOG_API_KEY=
# Datadog monitoring (optional)

# ═══════════════════════════════════════════════════════════════════════════
# Developer Configuration (Development Mode Only)
# ═══════════════════════════════════════════════════════════════════════════

# Debug Mode
DEBUG=false
# Set to true for verbose logging and stack traces

# Test Configuration
TEST_ENVIRONMENT=false
TEST_USE_MOCKS=true
# Set to true to use mock APIs instead of real ones

# Development Database
DEV_DATABASE_RESET_ON_START=false
# Set to true to clear and reinitialize the database on startup
